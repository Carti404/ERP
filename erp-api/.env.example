PORT=3000
# Base en Docker (erp-api): compose con trust en dev — puerto host 15433 (map 15433→5432).
# Si cambias auth o puerto: docker compose down -v && docker compose up -d
DB_HOST=localhost
DB_PORT=15433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=erp
# Si algo en Windows define DB_* incorrectas, puedes usar solo esta línea (y comenta las DB_* de arriba):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:15433/erp
# En desarrollo rápido puede ser true; en producción usar migraciones y false.
DB_SYNC=true
DB_LOGGING=false
JWT_SECRET=cambiar-por-secreto-largo-minimo-32-caracteres
JWT_EXPIRES_SEC=3600
CORS_ORIGIN=http://localhost:4200

# Solo seed:admin (opcional)
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PIN=0000
# SEED_ADMIN_NAME=Administrador
