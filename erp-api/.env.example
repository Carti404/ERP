PORT=3000
# Base en Docker (erp-api): compose con trust en dev — puerto host 15433 (map 15433→5432).
# Si cambias auth o puerto: docker compose down -v && docker compose up -d
DB_HOST=localhost
DB_PORT=15433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=erp
# Si algo en Windows define DB_* incorrectas, puedes usar solo esta línea (y comenta las DB_* de arriba):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:15433/erp
# --- CONFIGURACIÓN DE PRODUCCIÓN / DOCKER ---
# Indica si se deben correr las migraciones de TypeORM al arrancar el contenedor
RUN_MIGRATIONS=true
# Indica si se debe ejecutar el seed del administrador
RUN_SEED_ADMIN=true
# URL base de la API de Mundo Terapeuta para sincronización
MT_API_URL=http://localhost:3000

# Lista de orígenes permitidos por CORS separados por coma (ej: https://erp.com,https://mt.com)
CORS_ORIGIN=http://localhost:4200
